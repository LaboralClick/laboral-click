<!DOCTYPE html>
<html lang="es-MX">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Laboral Click - Asesoria Legal sin Enredos</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f8f9fa; color: #1a1a2e; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 25px; }
    
    header { background-color: white; box-shadow: 0 2px 25px rgba(0,0,0,0.08); padding: 12px 0; position: sticky; top: 0; z-index: 1000; }
    .nav { display: flex; justify-content: space-between; align-items: center; }
    .logo { font-size: 28px; font-weight: 700; color: #0a2463; text-decoration: none; }
    .logo span { color: #c9a028; display: block; font-size: 13px; font-weight: 500; letter-spacing: 1px; text-transform: uppercase; }
    .nav-links { display: flex; list-style: none; gap: 20px; }
    .nav-links a { text-decoration: none; color: #1a1a2e; font-weight: 500; font-size: 14px; transition: color 0.3s; }
    .nav-links a:hover { color: #c9a028; }
    .btn-whatsapp { background-color: #25D366; color: white; padding: 10px 20px; border-radius: 30px; text-decoration: none; font-weight: 600; font-size: 14px; display: inline-flex; align-items: center; gap: 7px; }
    .btn-whatsapp:hover { background-color: #1da851; }
    
    .menu-toggle { display: none; font-size: 30px; background: none; border: none; color: #0a2463; cursor: pointer; padding: 5px; }
    
    .hero { background: linear-gradient(150deg, #0a2463 0%, #1a3a7a 40%, #1e4d8c 100%); color: white; padding: 80px 0 60px; position: relative; overflow: hidden; }
    .hero::before { content: ''; position: absolute; top: -100px; right: -100px; width: 400px; height: 400px; background: rgba(201,160,40,0.08); border-radius: 50%; }
    .hero-content { display: grid; grid-template-columns: 1fr 400px; gap: 50px; align-items: center; }
    .hero-text h1 { font-size: 48px; line-height: 1.2; margin-bottom: 20px; font-weight: 700; }
    .hero-text .highlight { color: #f0c040; display: block; }
    .hero-text p { font-size: 19px; line-height: 1.7; margin-bottom: 35px; opacity: 0.95; max-width: 550px; }
    .hero-buttons { display: flex; gap: 15px; flex-wrap: wrap; }
    .btn-secundario { border: 2px solid #f0c040; color: #f0c040; padding: 15px 28px; border-radius: 30px; text-decoration: none; font-weight: 600; font-size: 15px; }
    .btn-secundario:hover { background-color: #f0c040; color: #0a2463; }
    
    .hero-image { text-align: center; }
    .hero-image img { width: 280px; height: 280px; border-radius: 50%; border: 5px solid #f0c040; object-fit: cover; box-shadow: 0 15px 40px rgba(0,0,0,0.3); }
    .hero-image .badge { background: #f0c040; color: #0a2463; padding: 8px 20px; border-radius: 25px; font-weight: 700; font-size: 14px; display: inline-block; margin-top: 15px; }
    
    .servicios { padding: 80px 0; background: white; }
    .section-title { text-align: center; font-size: 34px; font-weight: 700; color: #0a2463; margin-bottom: 10px; }
    .section-subtitle { text-align: center; color: #6B7280; font-size: 18px; margin-bottom: 50px; }
    .servicios-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 25px; }
    .servicio-card { background: #f8f9fa; padding: 40px 30px; border-radius: 12px; text-align: center; border: 1px solid #e5e7eb; }
    .servicio-card:hover { transform: translateY(-5px); box-shadow: 0 15px 35px rgba(0,0,0,0.1); border-color: #c9a028; }
    .servicio-icon { font-size: 48px; margin-bottom: 18px; }
    .servicio-card h3 { margin-bottom: 12px; font-size: 20px; color: #0a2463; }
    .servicio-card p { color: #6B7280; line-height: 1.6; font-size: 15px; }
    
    .calculadoras { padding: 80px 0; background: #0a2463; color: white; text-align: center; }
    .calculadoras h2 { font-size: 34px; margin-bottom: 40px; color: #f0c040; }
    .calc-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 25px; max-width: 800px; margin: 0 auto; }
    .calc-card { background: rgba(255,255,255,0.08); padding: 40px 30px; border-radius: 12px; }
    .calc-card:hover { background: rgba(255,255,255,0.15); }
    .calc-icon { font-size: 42px; margin-bottom: 12px; }
    .calc-card h3 { margin-bottom: 8px; font-size: 20px; }
    .calc-card p { margin-bottom: 18px; opacity: 0.85; font-size: 14px; }
    .btn-dorado { background-color: #f0c040; color: #0a2463; padding: 11px 24px; border-radius: 30px; text-decoration: none; font-weight: 700; font-size: 14px; display: inline-block; }
    .btn-dorado:hover { background-color: #e0b030; }
    
    .cta { background: linear-gradient(150deg, #1a3a7a, #0a2463); color: white; text-align: center; padding: 70px 0; }
    .cta h2 { font-size: 32px; margin-bottom: 15px; }
    .cta p { font-size: 18px; margin-bottom: 25px; opacity: 0.9; }
    
    footer { background: #060f2e; color: white; padding: 40px 0 20px; font-size: 14px; margin-top: 60px; }
    .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 30px; margin-bottom: 30px; text-align: left; }
    .footer-col h4 { color: #f0c040; margin-bottom: 12px; font-size: 16px; }
    .footer-col p { opacity: 0.85; line-height: 1.6; margin-bottom: 6px; }
    .footer-col a { color: #f0c040; text-decoration: none; }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px; text-align: center; }
    .disclaimer-text { opacity: 0.65; font-size: 12px; margin-bottom: 8px; font-style: italic; }
    .privacidad-text { opacity: 0.75; font-size: 13px; margin-bottom: 8px; }
    .copy { opacity: 0.6; font-size: 12px; margin-top: 10px; }
    
    .whatsapp-float { position: fixed; bottom: 30px; right: 30px; background-color: #25D366; color: white; width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 30px; text-decoration: none; box-shadow: 0 5px 25px rgba(37,211,102,0.5); z-index: 999; }

    @media (max-width: 900px) {
      .menu-toggle { display: block; }
      .nav-links { display: none; position: absolute; top: 100%; left: 0; right: 0; background: white; flex-direction: column; padding: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.15); gap: 12px; z-index: 999; }
      .nav-links.open { display: flex; }
      .hero-content { grid-template-columns: 1fr; text-align: center; }
      .hero-text h1 { font-size: 32px; }
      .hero-image img { width: 180px; height: 180px; }
      .btn-whatsapp { font-size: 12px; padding: 8px 15px; }
    }
    .hero-badge { display: inline-block; background: rgba(255,255,255,0.15); color: #f0c040; padding: 6px 18px; border-radius: 25px; font-size: 13px; font-weight: 600; margin-bottom: 20px; border: 1px solid rgba(240,192,64,0.3); }
.btn-urgente { background-color: #e74c3c; animation: pulse 2s infinite; }
.btn-urgente:hover { background-color: #c0392b; }
@keyframes pulse {
  0% { box-shadow: 0 0 0 0 rgba(231,76,60,0.5); }
  70% { box-shadow: 0 0 0 15px rgba(231,76,60,0); }
  100% { box-shadow: 0 0 0 0 rgba(231,76,60,0); }
}
.alerta-urgencia { background: #0d1b3e; color: white; padding: 50px 0; }
.alerta-content { display: flex; gap: 30px; align-items: center; max-width: 900px; margin: 0 auto; }
.alerta-icono { font-size: 55px; min-width: 70px; text-align: center; }
.alerta-content h2 { color: #f0c040; font-size: 24px; margin-bottom: 12px; }
.alerta-content p { opacity: 0.9; line-height: 1.7; margin-bottom: 15px; font-size: 15px; }
.alerta-content strong { color: #e74c3c; }
.alerta-cta { color: #f0c040; text-decoration: none; font-weight: 600; font-size: 15px; border-bottom: 2px solid #f0c040; padding-bottom: 2px; }
.alerta-cta:hover { color: white; border-bottom-color: white; }
@media (max-width: 600px) {
  .alerta-content { flex-direction: column; text-align: center; }
}
.sistema-laboral { padding: 80px 0; background: white; }
.sistema-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
.sistema-card { background: #f8f9fa; padding: 35px 25px; border-radius: 12px; text-align: center; border: 1px solid #e5e7eb; transition: all 0.3s; }
.sistema-card:hover { transform: translateY(-5px); box-shadow: 0 10px 30px rgba(0,0,0,0.1); border-color: #c9a028; }
.sistema-icono { font-size: 42px; margin-bottom: 12px; }
.sistema-card h3 { font-size: 17px; color: #0a2463; margin-bottom: 8px; }
.sistema-card p { color: #6B7280; font-size: 14px; line-height: 1.5; }
  </style>
</head>
