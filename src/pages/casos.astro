---
const titulo = "Casos de Exito";
---

<!DOCTYPE html>
<html lang="es-MX">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Casos de Exito - Laboral Click</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f8f9fa; color: #1a1a2e; }
    .container { max-width: 1000px; margin: 0 auto; padding: 0 25px; }
    
    header { background-color: white; box-shadow: 0 2px 25px rgba(0,0,0,0.08); padding: 12px 0; }
    .nav { display: flex; justify-content: space-between; align-items: center; }
    .logo { font-size: 28px; font-weight: 700; color: #0a2463; text-decoration: none; }
    .logo span { color: #c9a028; display: block; font-size: 13px; font-weight: 500; letter-spacing: 1px; }
    .nav-links { display: flex; list-style: none; gap: 28px; }
    .nav-links a { text-decoration: none; color: #1a1a2e; font-weight: 500; font-size: 15px; }
    .nav-links a:hover { color: #c9a028; }
    .btn-whatsapp { background-color: #25D366; color: white; padding: 11px 22px; border-radius: 30px; text-decoration: none; font-weight: 600; font-size: 14px; display: inline-flex; align-items: center; gap: 7px; }
    
    .page-hero { background: linear-gradient(150deg, #0a2463 0%, #1a3a7a 100%); color: white; padding: 70px 0; text-align: center; }
    .page-hero h1 { font-size: 38px; margin-bottom: 10px; }
    .page-hero p { font-size: 18px; color: #f0c040; }
    
    .casos-content { padding: 60px 0; }
    
    .caso-card { background: white; border-radius: 12px; padding: 40px; margin-bottom: 30px; box-shadow: 0 3px 20px rgba(0,0,0,0.06); display: grid; grid-template-columns: 80px 1fr; gap: 30px; align-items: start; }
    .caso-numero { width: 80px; height: 80px; background: #0a2463; color: #f0c040; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 32px; font-weight: 700; }
    .caso-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 10px; }
    .caso-header h2 { font-size: 24px; color: #0a2463; }
    .caso-badge { background: #25D366; color: white; padding: 6px 16px; border-radius: 20px; font-size: 13px; font-weight: 600; }
    .caso-secciones { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-bottom: 20px; }
    .caso-seccion { background: #f8f9fa; padding: 20px; border-radius: 8px; }
    .caso-seccion h4 { color: #0a2463; margin-bottom: 8px; font-size: 13px; text-transform: uppercase; letter-spacing: 1px; }
    .caso-seccion p { color: #6B7280; line-height: 1.6; font-size: 14px; }
    .caso-resultado { background: #f0fdf4; border: 2px solid #25D366; padding: 20px; border-radius: 8px; text-align: center; }
    .caso-resultado strong { color: #25D366; font-size: 20px; display: block; }
    .privacidad { font-size: 12px; color: #9ca3af; font-style: italic; margin-top: 8px; }
    
    .cta-final { text-align: center; padding: 50px; background: #0a2463; color: white; border-radius: 12px; margin-top: 40px; }
    .cta-final h2 { color: #f0c040; margin-bottom: 12px; }
    .cta-final p { margin-bottom: 20px; opacity: 0.9; }
    
    footer { background: #060f2e; color: white; padding: 40px 0 20px; font-size: 14px; margin-top: 60px; }
    .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 30px; margin-bottom: 30px; text-align: left; }
    .footer-col h4 { color: #f0c040; margin-bottom: 12px; font-size: 16px; }
    .footer-col p { opacity: 0.85; line-height: 1.6; margin-bottom: 6px; }
    .footer-col a { color: #f0c040; text-decoration: none; }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px; text-align: center; }
    .disclaimer-text { opacity: 0.65; font-size: 12px; margin-bottom: 8px; font-style: italic; }
    .privacidad-text { opacity: 0.75; font-size: 13px; margin-bottom: 8px; }
    .copy { opacity: 0.6; font-size: 12px; margin-top: 10px; }
    
    .whatsapp-float { position: fixed; bottom: 30px; right: 30px; background-color: #25D366; color: white; width: 65px; height: 65px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 34px; text-decoration: none; box-shadow: 0 5px 25px rgba(37,211,102,0.5); z-index: 1000; }

    @media (max-width: 768px) {
      .caso-card { grid-template-columns: 1fr; }
      .caso-secciones { grid-template-columns: 1fr; }
      .nav-links { display: none; }
    }
  </style>
</head>
