---
const titulo = "Precios";
---

<!DOCTYPE html>
<html lang="es-MX">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Precios - Laboral Click</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f8f9fa; color: #1a1a2e; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 25px; }
    
    header { background-color: white; box-shadow: 0 2px 25px rgba(0,0,0,0.08); padding: 12px 0; }
    .nav { display: flex; justify-content: space-between; align-items: center; }
    .logo { font-size: 28px; font-weight: 700; color: #0a2463; text-decoration: none; }
    .logo span { color: #c9a028; display: block; font-size: 13px; font-weight: 500; letter-spacing: 1px; }
    .nav-links { display: flex; list-style: none; gap: 28px; }
    .nav-links a { text-decoration: none; color: #1a1a2e; font-weight: 500; font-size: 15px; }
    .nav-links a:hover { color: #c9a028; }
    .btn-whatsapp { background-color: #25D366; color: white; padding: 11px 22px; border-radius: 30px; text-decoration: none; font-weight: 600; font-size: 14px; display: inline-flex; align-items: center; gap: 7px; }
    .menu-toggle { display: none; font-size: 30px; background: none; border: none; color: #0a2463; cursor: pointer; }
    
    .page-hero { background: linear-gradient(150deg, #0a2463 0%, #1a3a7a 100%); color: white; padding: 70px 0; text-align: center; }
    .page-hero h1 { font-size: 38px; margin-bottom: 10px; }
    .page-hero p { font-size: 18px; color: #f0c040; }
    
    .diferencial { text-align: center; padding: 30px; background: #fef9e7; border-radius: 12px; margin: 30px 0; border: 2px dashed #c9a028; }
    .diferencial p { font-size: 18px; color: #0a2463; font-weight: 600; }
    .diferencial span { color: #c9a028; }
    
    .precios-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(270px, 1fr)); gap: 25px; padding: 40px 0; }
    .plan-card { background: white; border-radius: 15px; padding: 35px 25px; box-shadow: 0 5px 30px rgba(0,0,0,0.06); position: relative; transition: transform 0.3s; display: flex; flex-direction: column; }
    .plan-card:hover { transform: translateY(-8px); }
    .plan-card.popular { border: 3px solid #c9a028; transform: scale(1.03); }
    .plan-card.popular:hover { transform: scale(1.03) translateY(-8px); }
    .plan-badge { position: absolute; top: -15px; left: 50%; transform: translateX(-50%); background: #c9a028; color: #0a2463; padding: 6px 20px; border-radius: 25px; font-weight: 700; font-size: 13px; }
    .plan-empresarial { border: 2px dashed #c9a028; background: #fef9e7; }
    
    .plan-nombre { font-size: 22px; font-weight: 700; color: #0a2463; margin-bottom: 5px; }
    .plan-desc { color: #6B7280; font-size: 14px; margin-bottom: 20px; }
    .plan-precio { font-size: 42px; font-weight: 700; color: #0a2463; margin-bottom: 5px; }
    .plan-precio small { font-size: 16px; color: #6B7280; font-weight: 400; }
    .plan-ahorro { color: #25D366; font-size: 13px; font-weight: 600; margin-bottom: 20px; }
    
    .plan-features { list-style: none; padding: 0; text-align: left; flex-grow: 1; }
    .plan-features li { padding: 10px 0; color: #4a4a5a; font-size: 14px; border-bottom: 1px solid #f0f0f0; line-height: 1.5; }
    .plan-features li strong { color: #0a2463; }
    
    .plan-btn { display: block; margin-top: 20px; padding: 14px; border-radius: 30px; text-decoration: none; font-weight: 700; font-size: 15px; text-align: center; }
    .btn-dorado { background: #c9a028; color: #0a2463; }
    .btn-dorado:hover { background: #b8901e; }
    .btn-outline { border: 2px solid #c9a028; color: #c9a028; }
    .btn-outline:hover { background: #c9a028; color: #0a2463; }
    
    .garantia { text-align: center; padding: 30px; background: #f0fdf4; border-radius: 12px; margin: 30px 0; border: 2px solid #25D366; }
    .garantia h3 { color: #25D366; font-size: 22px; margin-bottom: 8px; }
    .garantia p { color: #4a4a5a; }
    
    .faq-section { padding: 40px 0; }
    .faq-section h2 { text-align: center; color: #0a2463; margin-bottom: 30px; }
    .faq-item { background: white; border-radius: 10px; padding: 20px 25px; margin-bottom: 10px; cursor: pointer; }
    .faq-item h3 { font-size: 16px; color: #0a2463; }
    .faq-item p { color: #6B7280; margin-top: 8px; display: none; }
    .faq-item.open p { display: block; }
    
    .cta-final { text-align: center; padding: 50px; background: #0a2463; color: white; border-radius: 15px; margin: 40px 0; }
    .cta-final h2 { color: #f0c040; margin-bottom: 10px; }
    .cta-final p { opacity: 0.9; margin-bottom: 20px; }
    
    footer { background: #060f2e; color: white; padding: 40px 0 20px; font-size: 14px; margin-top: 60px; }
    .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 30px; margin-bottom: 30px; text-align: left; }
    .footer-col h4 { color: #f0c040; margin-bottom: 12px; font-size: 16px; }
    .footer-col p { opacity: 0.85; line-height: 1.6; }
    .footer-col a { color: #f0c040; text-decoration: none; }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px; text-align: center; }
    .disclaimer-text { opacity: 0.65; font-size: 12px; font-style: italic; }
    .privacidad-text { opacity: 0.75; font-size: 13px; }
    .copy { opacity: 0.6; font-size: 12px; margin-top: 10px; }
    
    .whatsapp-float { position: fixed; bottom: 30px; right: 30px; background-color: #25D366; color: white; width: 65px; height: 65px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 34px; text-decoration: none; box-shadow: 0 5px 25px rgba(37,211,102,0.5); z-index: 1000; }

    @media (max-width: 768px) {
      .menu-toggle { display: block; }
      .nav-links { display: none; position: absolute; top: 100%; left: 0; right: 0; background: white; flex-direction: column; padding: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.15); gap: 12px; z-index: 999; }
      .nav-links.open { display: flex; }
      .plan-card.popular { transform: none; }
      .plan-card.popular:hover { transform: translateY(-8px); }
    }
  </style>
</head>
